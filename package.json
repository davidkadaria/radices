{
  "name": "radices",
  "version": "1.0.0",
  "description": "Monorepo of single-document essays sharing one build engine. Scaffold with `npm run add-project --name <name>`, build with `npm run build-project --name <name>`.",
  "scripts": {
    "add-project": "node engine/add-project.js",
    "build-project": "node engine/build.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidkadaria/radices.git"
  },
  "author": "Dato Kadaria",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Rad1ceS/radices/issues"
  },
  "dependencies": {
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.34.5",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "clean-css": "^5.3.3",
    "html-minifier-terser": "^7.2.0",
    "terser": "^5.46.0"
  }
}
